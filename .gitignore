# --- Environment & secrets ----------------------------------------------------
# Never commit real env files. Only .env.example is safe to share.
.env
.env.*
!.env.example

# --- Python -------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# --- IDEs / editors -----------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Project-specific (job_search_tool) ---------------------------------------
# User's private resume and tracker
job_search_tool/resume/*
job_search_tool/data/*

# Generated outputs are reproducible — keep the dirs (via .gitkeep) but not the contents
job_search_tool/output/cover_letters/*
job_search_tool/output/tailored_resumes/*
!job_search_tool/output/cover_letters/.gitkeep
!job_search_tool/output/tailored_resumes/.gitkeep

# Ollama / model caches (in case the tool ever pulls models)
.ollama/
ollama_models/
